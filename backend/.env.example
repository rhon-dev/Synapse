# =====================================================================
# Synapse — environment template
# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored. NEVER commit real credentials.
# =====================================================================

# --- OpenAI -----------------------------------------------------------
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-real-key-here
OPENAI_MODEL=gpt-4o

# --- MongoDB (data layer) ---------------------------------------------
# Local mongod:
#   MONGO_URI=mongodb://localhost:27017
# Atlas (Connect → Drivers → copy SRV string, replace <password>):
#   MONGO_URI=mongodb+srv://USER:PASSWORD@cluster-xxx.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
DB_NAME=synapse

# --- Atlas Admin API v2 (cluster/user management — optional) ----------
# Only needed if you want /atlas/* endpoints to work.
# Create a Programmatic API key:
#   Atlas → Access Manager → API Keys → Create Organization API Key
#   Grant role "Organization Read Only" (or higher).
#   Add the public key to your Project → Access Manager → API Keys.
# Find Project ID:
#   Atlas → Project → Settings → Project ID (24-char hex).
ATLAS_API_PUBLIC_KEY=your_public_key_here
ATLAS_API_PRIVATE_KEY=your_private_key_uuid_here
ATLAS_PROJECT_ID=24charhexprojectid000000
ATLAS_API_BASE_URL=https://cloud.mongodb.com/api/atlas/v2
ATLAS_API_VERSION=2025-03-12
