# =====================================================================
# Synapse — environment template
# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored. NEVER commit real credentials.
# =====================================================================

# --- LLM provider (OpenAI-compatible) ---------------------------------
# Synapse uses the OpenAI Python SDK, which talks to any OpenAI-API-
# compatible endpoint. Pick one of these provider preset blocks:
#
# --- Option 1: OpenAI ---
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=                      (leave empty — SDK default)
#   OPENAI_MODEL=gpt-4o
#
# --- Option 2: Groq (free, fast, recommended) ---
#   Sign up: https://console.groq.com/keys  (no credit card)
#   OPENAI_API_KEY=gsk_...
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_MODEL=llama-3.3-70b-versatile
#
# --- Option 3: Google Gemini (free) ---
#   Sign up: https://aistudio.google.com/apikey
#   OPENAI_API_KEY=AIza...
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   OPENAI_MODEL=gemini-1.5-flash
#
# --- Option 4: Ollama (local, 100% free, no key) ---
#   brew install ollama && ollama pull llama3.2
#   OPENAI_API_KEY=ollama                 (anything non-empty)
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_MODEL=llama3.2

OPENAI_API_KEY=gsk_your_groq_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# --- MongoDB (data layer) ---------------------------------------------
# Local mongod:
#   MONGO_URI=mongodb://localhost:27017
# Atlas (Connect → Drivers → copy SRV string, replace <password>):
#   MONGO_URI=mongodb+srv://USER:PASSWORD@cluster-xxx.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
DB_NAME=synapse

# --- Atlas Admin API v2 (cluster/user management — optional) ----------
# Only needed if you want /atlas/* endpoints to work.
# Create a Programmatic API key:
#   Atlas → Access Manager → API Keys → Create Organization API Key
#   Grant role "Organization Read Only" (or higher).
#   Add the public key to your Project → Access Manager → API Keys.
# Find Project ID:
#   Atlas → Project → Settings → Project ID (24-char hex).
ATLAS_API_PUBLIC_KEY=your_public_key_here
ATLAS_API_PRIVATE_KEY=your_private_key_uuid_here
ATLAS_PROJECT_ID=24charhexprojectid000000
ATLAS_API_BASE_URL=https://cloud.mongodb.com/api/atlas/v2
ATLAS_API_VERSION=2025-03-12
