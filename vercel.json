{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb", "runtime": "python3.12" }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/static/(.*)",       "dest": "/frontend/$1" },
    { "src": "/favicon.ico",       "dest": "/frontend/favicon.ico" },
    { "src": "/",                  "dest": "/frontend/index.html" },
    { "src": "/(.*)",              "dest": "/api/index.py" }
  ]
}
